# Server
PORT=3001
NODE_ENV=development

# Optional HTTP Basic Auth (leave empty to disable)
APP_AUTH_USER=
APP_AUTH_PASS=

# gosom scraper container
GOSOM_URL=http://gosom:8080

# Database (SQLite file path)
DATABASE_URL=./data/scraper.db

# Google Sheets service account
GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/google-service-account.json

# Gemini AI (required for email composition)
GEMINI_API_KEY=your-gemini-api-key

# Gmail outreach
GMAIL_FROM=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_SENDER_NAME=Your Name

# Social enrichment crawler
SOCIAL_ENRICHMENT_DELAY_MS=1000
SOCIAL_ENRICHMENT_TIMEOUT_MS=8000
SOCIAL_ENRICHMENT_MAX_BYTES=2097152

# Map defaults (Buenos Aires)
DEFAULT_CENTER_LAT=-34.6037
DEFAULT_CENTER_LNG=-58.3816
DEFAULT_ZOOM=13
DEFAULT_GRID_CELL_KM=0.4

# Google PageSpeed Insights (optional; premium analysis degrades to UNKNOWN if absent)
PAGESPEED_API_KEY=your-pagespeed-api-key